# L2Earn env vars

# 1. WalletConnect project ID — required for the wallet modal to open.
#    Free, sign up at https://walletconnect.network
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=c14793a6ed715ebd928933fd97afc5de

# 2. Anthropic API key — used server-side to generate + grade quiz questions.
#    Optional: if unset, L2Earn falls back to a deterministic stub quiz.
#    Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=
